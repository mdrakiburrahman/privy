# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# After editing, load into your shell with:  set -a; source .env; set +a

# --- Azure Storage (used by scripts/upload_whl.sh) -----------------------------
STORAGE_KEY="<storage-account-key-for>"

# --- Azure Relay Hybrid Connection (used by demos and pytest e2e tests) -------
# namespace is just the short name (no .servicebus.windows.net suffix)
PRIVY_RELAY_NAMESPACE="<e.g. foo-dev-relay>"
PRIVY_RELAY_PATH="<hybrid connection name, e.g. demo>"
PRIVY_RELAY_KEYRULE="<SAS authorization rule name with Listen+Send rights>"
PRIVY_RELAY_KEY="<primary key for the SAS rule above>"
